{
  "name": "lodesta",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit --incremental false",
    "smoke": "bash scripts/smoke.sh",
    "smoke:dev": "bash scripts/smoke.sh --start-server",
    "cli": "node scripts/lodesta.mjs",
    "worker": "node --import tsx workers/runner.ts",
    "verify:launch-boundaries": "node --import tsx scripts/verify-launch-boundaries.ts",
    "verify:stripe-webhook": "node --import tsx scripts/verify-stripe-webhook.ts",
    "verify:supabase": "node --import tsx scripts/verify-supabase.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
